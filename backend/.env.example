# Server Configuration
PORT=3001
NODE_ENV=production
HOST=0.0.0.0

# Security
JWT_SECRET=change-this-to-a-strong-random-secret-key
JWT_EXPIRES_IN=12h
# When true, JWT auth + role-based access control are enforced
ENABLE_AUTH=true
TRUST_PROXY=1
ENFORCE_PROD_SECURITY=true

# Database
DATABASE_PATH=./data/ssh-manager.db

# SSH Configuration
SSH_KEY_PATH=/home/user/.ssh/
MAX_SSH_CONNECTIONS=50

# Docker Configuration
DOCKER_SOCKET=/var/run/docker.sock

# Proxmox API Configuration
# Example token id format: root@pam!dashboard
# Optional: can be overridden from Proxmox tab target input
PROXMOX_API_URL=https://proxmox.local:8006
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
# Set true only for self-signed certificates in trusted networks
PROXMOX_TLS_INSECURE=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# CORS
CORS_ORIGIN=https://your-domain.example

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
